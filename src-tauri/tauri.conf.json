{
  "$schema": "https://raw.githubusercontent.com/nicegui/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "PoeScout",
  "version": "0.1.0",
  "identifier": "com.poescout.app",
  "build": {
    "frontendDist": "../packages/ui/dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "pnpm --filter ui dev",
    "beforeBuildCommand": "pnpm --filter ui build"
  },
  "app": {
    "windows": [
      {
        "title": "PoeScout",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
